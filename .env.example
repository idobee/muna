# ============================================================
# 🎵 뮤나(Muna) AI 에이전트 - 환경변수 템플릿
# 이 파일을 복사해서 .env 로 이름을 바꾼 후 값을 채우세요.
# cp .env.example .env
# ============================================================

# ── YouTube Data API v3 ──────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here
YOUTUBE_CLIENT_ID=your_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# ── GitHub 설정 ──────────────────────────────────────────────
GITHUB_REPO_OWNER=idobee
GITHUB_REPO_NAME=muna
GITHUB_BRANCH=master

# ── 채널 기본 정보 ───────────────────────────────────────────
CHANNEL_NAME=your_channel_name
CHANNEL_LANGUAGE=ko
TARGET_TIMEZONE=Asia/Seoul

# ── 업로드 스케줄 설정 ──────────────────────────────────────
UPLOAD_WEEKDAY_HOUR=18
UPLOAD_WEEKDAY_MINUTE=00
UPLOAD_WEEKEND_HOUR=12
UPLOAD_WEEKEND_MINUTE=00

# ── AI 설정 ────────────────────────────────────────────────
AGENT_NAME=muna
AGENT_VERSION=1.0

# ── 알림 설정 (선택사항) ────────────────────────────────────
NOTIFY_EMAIL=
SLACK_WEBHOOK_URL=
